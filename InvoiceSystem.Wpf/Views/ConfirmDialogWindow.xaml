<Window x:Class="InvoiceSystem.Wpf.Views.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="確認"
        Width="500"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Grid>
        <Border Background="#66000000"
                CornerRadius="24"/>

        <Border Margin="18"
                CornerRadius="24"
                BorderBrush="#334155"
                BorderThickness="1"
                Background="#EE0F172A">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30"
                                  ShadowDepth="0"
                                  Opacity="0.35"
                                  Color="#000000"/>
            </Border.Effect>

            <Grid Margin="26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ヘッダ -->
                <StackPanel Grid.Row="0">
                    <Border HorizontalAlignment="Left"
                            Background="#1E293B"
                            CornerRadius="999"
                            Padding="10,4">
                        <TextBlock Text="Invoice System"
                                   Foreground="#7DD3FC"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock x:Name="TitleText"
                               Margin="0,16,0,0"
                               Text="確認"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <!-- 本文 -->
                <Border Grid.Row="2"
                        CornerRadius="18"
                        Padding="18"
                        Background="#0B1220"
                        BorderBrush="#233044"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="IconBadge"
                                Grid.Row="0"
                                Width="52"
                                Height="52"
                                CornerRadius="26"
                                Background="#132032"
                                BorderBrush="#155E75"
                                BorderThickness="1"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                            <TextBlock x:Name="IconText"
                                       Text="?"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#7DD3FC"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock x:Name="MessageText"
                                   Grid.Row="2"
                                   Text="実行してもよろしいですか？"
                                   Foreground="#E2E8F0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="SubMessageText"
                                   Grid.Row="4"
                                   Margin="0,0,0,0"
                                   Text=""
                                   Foreground="#94A3B8"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- ボタン -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="CancelButton"
                            Grid.Column="2"
                            Height="42"
                            Content="キャンセル"
                            Click="CancelButton_OnClick"
                            Background="#1E293B"
                            Foreground="#E2E8F0"
                            BorderBrush="#475569"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="ConfirmButton"
                            Grid.Column="4"
                            Height="42"
                            Content="OK"
                            Click="ConfirmButton_OnClick"
                            Background="#0EA5E9"
                            Foreground="White"
                            BorderBrush="#0EA5E9"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>