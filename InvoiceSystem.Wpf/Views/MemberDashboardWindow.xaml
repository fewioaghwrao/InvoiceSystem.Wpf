<Window x:Class="InvoiceSystem.Wpf.Views.MemberDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="会員用ダッシュボード"
        Height="960"
        Width="1120"
        MinHeight="900"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#0B1120">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Background" Value="#CC0F172A"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="26"
                                      ShadowDepth="0"
                                      Opacity="0.20"
                                      Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="QuickActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="168"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="#0EA5E9"/>
            <Setter Property="BorderBrush" Value="#0EA5E9"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="#3F1D1D"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#132032"/>
            <Setter Property="BorderBrush" Value="#334155"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.35"/>
                <GradientStop Color="#111827" Offset="0.72"/>
                <GradientStop Color="#1E1B4B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 装飾 -->
        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-100,0,0"
                 IsHitTestVisible="False"
                 Opacity="0.16">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#38BDF8" Offset="0"/>
                    <GradientStop Color="#0038BDF8" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="440"
                 Height="440"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-130,-100"
                 IsHitTestVisible="False"
                 Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#006366F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ヘッダー -->
            <Border Grid.Row="0"
                    CornerRadius="24"
                    Padding="24"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border HorizontalAlignment="Left"
                                Background="#1E293B"
                                CornerRadius="999"
                                Padding="10,4">
                            <TextBlock Text="Invoice System / Member"
                                       Foreground="#7DD3FC"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock Text="会員用ダッシュボード"
                                   Margin="0,16,0,0"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="自分の請求書、未入金状況、登録情報を確認するためのメイン画面です。"
                                   Margin="0,8,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Border Style="{StaticResource StatusBadgeStyle}"
                                HorizontalAlignment="Right"
                                Background="#0B2A1E"
                                BorderBrush="#14532D">
                            <TextBlock x:Name="RoleBadgeText"
                                       Text="一般会員"
                                       Foreground="#86EFAC"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock x:Name="WelcomeText"
                                   Margin="0,14,0,0"
                                   HorizontalAlignment="Right"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="ようこそ、会員さま"/>

                        <TextBlock x:Name="SubWelcomeText"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Right"
                                   Foreground="#94A3B8"
                                   FontSize="12"
                                   Text="ログイン情報を読み込みました。"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 本文 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左カラム -->
                <StackPanel Grid.Column="0">
                    <!-- ユーザー情報 -->
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="ログイン中の情報"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <TextBlock Margin="0,8,0,0"
                                       Text="現在のログインユーザー情報を表示します。"
                                       Style="{StaticResource MutedTextStyle}"/>

                            <Border Margin="0,18,0,0"
                                    CornerRadius="16"
                                    Padding="16"
                                    Background="#0B1220"
                                    BorderBrush="#233044"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="氏名"
                                                   Foreground="#94A3B8"
                                                   FontSize="11"/>
                                        <TextBlock x:Name="NameText"
                                                   Margin="0,6,0,0"
                                                   Text="---"
                                                   Style="{StaticResource ValueTextStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2">
                                        <TextBlock Text="メールアドレス"
                                                   Foreground="#94A3B8"
                                                   FontSize="11"/>
                                        <TextBlock x:Name="EmailText"
                                                   Margin="0,6,0,0"
                                                   Text="---"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4">
                                        <TextBlock Text="ロール"
                                                   Foreground="#94A3B8"
                                                   FontSize="11"/>
                                        <TextBlock x:Name="RoleText"
                                                   Margin="0,6,0,0"
                                                   Text="一般会員"
                                                   Style="{StaticResource ValueTextStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}"
                            Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="お知らせ"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#CBD5E1"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Text="この画面では、自分の請求情報の確認・未入金把握・登録情報確認を行えます。Lite版のため、まずは導線を分かりやすく整理しています。"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 右カラム -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="できること"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#CBD5E1"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Text="請求書の一覧・支払期限・入金状況を確認し、必要な情報へすばやく移動できます。"/>

                            <WrapPanel Margin="0,16,0,0">
                                <Border Style="{StaticResource StatusBadgeStyle}"
                                        Background="#132032"
                                        BorderBrush="#155E75"
                                        Margin="0,0,10,10">
                                    <TextBlock Text="請求書確認"
                                               Foreground="#7DD3FC"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>

                                <Border Style="{StaticResource StatusBadgeStyle}"
                                        Background="#2B1B11"
                                        BorderBrush="#92400E"
                                        Margin="0,0,10,10">
                                    <TextBlock Text="未入金確認"
                                               Foreground="#FCD34D"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>

                                <Border Style="{StaticResource StatusBadgeStyle}"
                                        Background="#0B2A1E"
                                        BorderBrush="#166534"
                                        Margin="0,0,10,10">
                                    <TextBlock Text="登録情報確認"
                                               Foreground="#86EFAC"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 請求書一覧 -->
                        <Button Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource QuickActionButtonStyle}"
                                Click="InvoicesButton_OnClick"
                                Background="#0F172A"
                                BorderBrush="#1D4ED8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <Border Width="46"
                                            Height="46"
                                            CornerRadius="23"
                                            Background="#0C2340"
                                            BorderBrush="#1D4ED8"
                                            BorderThickness="1"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="📄"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="22"
                                                   Margin="0,8,0,0"/>
                                    </Border>

                                    <TextBlock Margin="0,14,0,0"
                                               Text="請求書一覧"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <TextBlock Grid.Row="2"
                                           Margin="0,0,0,0"
                                           Foreground="#CBD5E1"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Text="自分の請求書、金額、支払期限、入金状況を確認します。"/>

                                <TextBlock Grid.Row="3"
                                           Margin="0,14,0,0"
                                           Foreground="#7DD3FC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="開く →"/>
                            </Grid>
                        </Button>

                        <!-- 未入金 -->
                        <Button Grid.Row="0"
                                Grid.Column="2"
                                Style="{StaticResource QuickActionButtonStyle}"
                                Click="UnpaidButton_OnClick"
                                Background="#0F172A"
                                BorderBrush="#D97706">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <Border Width="46"
                                            Height="46"
                                            CornerRadius="23"
                                            Background="#2B1B11"
                                            BorderBrush="#D97706"
                                            BorderThickness="1"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="⏳"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="22"
                                                   Margin="0,8,0,0"/>
                                    </Border>

                                    <TextBlock Margin="0,14,0,0"
                                               Text="未入金確認"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <TextBlock Grid.Row="2"
                                           Foreground="#CBD5E1"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Text="未入金や確認が必要な請求情報を把握します。"/>

                                <TextBlock Grid.Row="3"
                                           Margin="0,14,0,0"
                                           Foreground="#FCD34D"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="開く →"/>
                            </Grid>
                        </Button>

                        <!-- 登録情報 -->
                        <Button Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Style="{StaticResource QuickActionButtonStyle}"
                                Click="ProfileButton_OnClick"
                                Background="#0F172A"
                                BorderBrush="#059669">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="56"
                                        Height="56"
                                        CornerRadius="28"
                                        Background="#0B2A1E"
                                        BorderBrush="#059669"
                                        BorderThickness="1"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="👤"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="26"
                                               Margin="0,10,0,0"/>
                                </Border>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="登録情報確認"
                                               Foreground="White"
                                               FontSize="20"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#CBD5E1"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Text="氏名、メール、住所などの登録情報を確認・変更する画面へ進みます。"/>
                                </StackPanel>

                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Bottom"
                                           Foreground="#86EFAC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="開く →"/>
                            </Grid>
                        </Button>
                    </Grid>

                    <Border Grid.Row="4"
                            Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="セッション操作"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Margin="0,8,0,0"
                                           Text="ログアウト、またはログイン画面へ戻ることができます。"
                                           Style="{StaticResource MutedTextStyle}"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Content="ログイン画面へ戻る"
                                    Click="BackToLoginButton_OnClick"/>

                            <Button Grid.Column="4"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Content="ログアウト"
                                    Click="LogoutButton_OnClick"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- フッター -->
            <Border Grid.Row="4"
                    CornerRadius="18"
                    Padding="14,12"
                    BorderBrush="#233044"
                    BorderThickness="1"
                    Background="#99101826">
                <TextBlock x:Name="FooterText"
                           Text="Invoice &amp; Payment Status Dashboard (Lite) / Member Dashboard"
                           Foreground="#64748B"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>