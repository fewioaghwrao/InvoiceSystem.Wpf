<Window x:Class="InvoiceSystem.Wpf.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新規会員登録"
        Height="680"
        Width="980"
        MinHeight="680"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0B1120">

    <Grid>
        <!-- 背景 -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.35"/>
                <GradientStop Color="#111827" Offset="0.7"/>
                <GradientStop Color="#1E1B4B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 背景演出 -->
        <Ellipse Width="360"
                 Height="360"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-90,-70,0,0"
                 IsHitTestVisible="False"
                 Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#38BDF8" Offset="0"/>
                    <GradientStop Color="#0038BDF8" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-120,-100"
                 IsHitTestVisible="False"
                 Opacity="0.16">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#006366F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- メインカード -->
        <Grid Margin="28">
            <Border MaxWidth="920"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="26"
                    Padding="0"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32"
                                      ShadowDepth="0"
                                      Opacity="0.30"
                                      Color="#000000"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="1.35*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左カラム：案内 -->
                    <Border Grid.Column="0"
                            Padding="34,34,28,34"
                            Background="#220F172A">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <Border HorizontalAlignment="Left"
                                        Background="#1E293B"
                                        CornerRadius="999"
                                        Padding="10,4">
                                    <TextBlock Text="Invoice System"
                                               Foreground="#7DD3FC"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                </Border>

                                <TextBlock Text="新規会員登録"
                                           Margin="0,18,0,0"
                                           Foreground="White"
                                           FontSize="28"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="請求書・入金ステータス管理用のアカウントを新規作成します。"
                                           Margin="0,10,0,0"
                                           Foreground="#CBD5E1"
                                           FontSize="14"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Border Grid.Row="2"
                                    CornerRadius="18"
                                    Padding="16"
                                    Background="#0F172A"
                                    BorderBrush="#334155"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="登録のポイント"
                                               Foreground="White"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="• 氏名・メールアドレス・パスワードだけでも登録できます。"
                                               Margin="0,12,0,0"
                                               Foreground="#94A3B8"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="• メールアドレスはログインIDとして使用します。"
                                               Margin="0,8,0,0"
                                               Foreground="#94A3B8"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="• 郵便番号・電話番号・住所は任意入力です。"
                                               Margin="0,8,0,0"
                                               Foreground="#94A3B8"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="4">
                                <TextBlock Text="利用イメージ"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="登録後は、ログイン画面からサインインし、請求書一覧や入金状況の確認などを行える想定です。"
                                           Margin="0,10,0,0"
                                           Foreground="#94A3B8"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Border Grid.Row="6"
                                    VerticalAlignment="Bottom"
                                    CornerRadius="16"
                                    Padding="14"
                                    Background="#1E293B">
                                <TextBlock Text="ダミー情報でも問題ありません（ポートフォリオ用）。"
                                           Foreground="#BFDBFE"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 区切り線 -->
                    <Border Grid.Column="1"
                            Background="#334155"
                            Opacity="0.8"/>

                    <!-- 右カラム：フォーム -->
                    <Border Grid.Column="2"
                            Padding="34">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- フォーム見出し -->
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="アカウント情報入力"
                                               Foreground="White"
                                               FontSize="22"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="必須項目を入力して、アカウントを作成してください。"
                                               Margin="0,8,0,0"
                                               Foreground="#94A3B8"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- 氏名 / メール -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="氏名"
                                                   Foreground="#E2E8F0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <Border CornerRadius="12"
                                                BorderBrush="#475569"
                                                BorderThickness="1"
                                                Background="#0F172A">
                                            <TextBox Height="42"
                                                     Padding="12,8"
                                                     Background="Transparent"
                                                     Foreground="White"
                                                     BorderThickness="0"
                                                     CaretBrush="White"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="メールアドレス"
                                                   Foreground="#E2E8F0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <Border CornerRadius="12"
                                                BorderBrush="#475569"
                                                BorderThickness="1"
                                                Background="#0F172A">
                                            <TextBox Height="42"
                                                     Padding="12,8"
                                                     Background="Transparent"
                                                     Foreground="White"
                                                     BorderThickness="0"
                                                     CaretBrush="White"
                                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- パスワード -->
                                <StackPanel Grid.Row="4">
                                    <TextBlock Text="パスワード"
                                               Foreground="#E2E8F0"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="86"/>
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="PasswordBoxBorder"
                                                Grid.Column="0"
                                                CornerRadius="12"
                                                BorderBrush="#475569"
                                                BorderThickness="1"
                                                Background="#0F172A">
                                            <PasswordBox x:Name="PasswordBox"
                                                         Height="42"
                                                         Padding="12,8"
                                                         Background="Transparent"
                                                         Foreground="White"
                                                         BorderThickness="0"
                                                         PasswordChanged="PasswordBox_OnPasswordChanged"/>
                                        </Border>

                                        <Border x:Name="VisiblePasswordBorder"
                                                Grid.Column="0"
                                                CornerRadius="12"
                                                BorderBrush="#475569"
                                                BorderThickness="1"
                                                Background="#0F172A"
                                                Visibility="Collapsed">
                                            <TextBox x:Name="VisiblePasswordTextBox"
                                                     Height="42"
                                                     Padding="12,8"
                                                     Background="Transparent"
                                                     Foreground="White"
                                                     BorderThickness="0"
                                                     CaretBrush="White"
                                                     TextChanged="VisiblePasswordTextBox_OnTextChanged"/>
                                        </Border>

                                        <Button x:Name="TogglePasswordButton"
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Height="42"
                                                Content="表示"
                                                Click="TogglePasswordButton_OnClick"
                                                Background="#1E293B"
                                                Foreground="#E2E8F0"
                                                BorderBrush="#475569"
                                                BorderThickness="1"
                                                FontWeight="SemiBold"/>
                                    </Grid>

                                    <TextBlock Text="英数字・記号を組み合わせた8文字以上を推奨"
                                               Margin="4,8,0,0"
                                               Foreground="#94A3B8"
                                               FontSize="11"/>
                                </StackPanel>

                                <!-- 郵便番号 / 電話番号 -->
                                <Grid Grid.Row="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="郵便番号"
                                                   Foreground="#E2E8F0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <Border CornerRadius="12"
                                                BorderBrush="#475569"
                                                BorderThickness="1"
                                                Background="#0F172A">
                                            <TextBox Height="42"
                                                     Padding="12,8"
                                                     Background="Transparent"
                                                     Foreground="White"
                                                     BorderThickness="0"
                                                     CaretBrush="White"
                                                     Text="{Binding PostalCode, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="電話番号"
                                                   Foreground="#E2E8F0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <Border CornerRadius="12"
                                                BorderBrush="#475569"
                                                BorderThickness="1"
                                                Background="#0F172A">
                                            <TextBox Height="42"
                                                     Padding="12,8"
                                                     Background="Transparent"
                                                     Foreground="White"
                                                     BorderThickness="0"
                                                     CaretBrush="White"
                                                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- 住所 -->
                                <StackPanel Grid.Row="8">
                                    <TextBlock Text="住所"
                                               Foreground="#E2E8F0"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>
                                    <Border CornerRadius="12"
                                            BorderBrush="#475569"
                                            BorderThickness="1"
                                            Background="#0F172A">
                                        <TextBox Height="42"
                                                 Padding="12,8"
                                                 Background="Transparent"
                                                 Foreground="White"
                                                 BorderThickness="0"
                                                 CaretBrush="White"
                                                 Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" />
                                    </Border>
                                </StackPanel>

                                <!-- エラー -->
                                <Border Grid.Row="10"
                                        Background="#3F1D1D"
                                        BorderBrush="#7F1D1D"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12"
                                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Foreground="#FCA5A5"
                                               TextWrapping="Wrap"
                                               FontSize="12"/>
                                </Border>

                                <!-- 成功 -->
                                <Border Grid.Row="12"
                                        Background="#0F3D2E"
                                        BorderBrush="#065F46"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12"
                                        Visibility="{Binding HasSuccess, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding SuccessMessage}"
                                               Foreground="#A7F3D0"
                                               TextWrapping="Wrap"
                                               FontSize="12"/>
                                </Border>

                                <!-- 補足 -->
                                <TextBlock Grid.Row="14"
                                           Foreground="#64748B"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="登録後はログイン画面からサインインしてください。"/>

                                <!-- ボタン -->
                                <Grid Grid.Row="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Height="46"
                                            Content="アカウントを作成する"
                                            Command="{Binding RegisterCommand}"
                                            Background="#0EA5E9"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            FontSize="14"/>

                                    <Button Grid.Column="2"
                                            Height="46"
                                            Content="閉じる"
                                            Click="CloseButton_OnClick"
                                            Background="Transparent"
                                            Foreground="#CBD5E1"
                                            BorderBrush="#475569"
                                            BorderThickness="1"
                                            FontWeight="SemiBold"/>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>