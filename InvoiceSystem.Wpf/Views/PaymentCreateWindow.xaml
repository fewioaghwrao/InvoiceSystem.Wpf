<Window x:Class="InvoiceSystem.Wpf.Views.PaymentCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="入金登録"
        Width="980"
        Height="720"
        MinWidth="920"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#020617">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="TextBoxStyleDark" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="ComboBoxStyleDark" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.5"/>
                <GradientStop Color="#111827" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="20"
                    Padding="20"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="入金登録（手動）"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="入金日・金額・入金名義を入力して登録します。登録後に詳細へ進みます。"
                                   Margin="0,8,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="閉じる"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CloseButton_OnClick"/>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="#3F1D1D"
                    BorderBrush="#7F1D1D"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FCA5A5"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="4"
                    CornerRadius="18"
                    Padding="20"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="会員（入金元）"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Members}"
                                  SelectedItem="{Binding SelectedMember}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ComboBoxStyleDark}"/>
                        <TextBlock Text="※ 一般かつ有効な会員を表示します。"
                                   Margin="0,6,0,0"
                                   Foreground="#64748B"
                                   FontSize="11"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="入金日"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding PaymentDate}"
                                        Height="38"/>
                            <TextBlock Text="例：当日入金日を初期値にしています。"
                                       Margin="0,6,0,0"
                                       Foreground="#64748B"
                                       FontSize="11"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="入金名義"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding PayerName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyleDark}"
                                     TextChanged="PayerNameTextBox_OnTextChanged"/>
                            <TextBlock Text="※ 会員選択時に会員名を初期値にします。必要に応じて編集してください。"
                                       Margin="0,6,0,0"
                                       Foreground="#64748B"
                                       FontSize="11"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="入金額（円）"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyleDark}"/>
                            <TextBlock Text="例：60000"
                                       Margin="0,6,0,0"
                                       Foreground="#64748B"
                                       FontSize="11"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="入金方法"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding MethodOptions}"
                                      SelectedItem="{Binding SelectedMethod}"
                                      DisplayMemberPath="Label"
                                      Style="{StaticResource ComboBoxStyleDark}"/>
                            <TextBlock Text="※ 任意項目です。"
                                       Margin="0,6,0,0"
                                       Foreground="#64748B"
                                       FontSize="11"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="6"
                            Padding="14"
                            CornerRadius="14"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            Background="#0F172A">
                        <StackPanel>
                            <TextBlock Text="登録内容"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="会員・入金日・入金名義・入金額・入金方法を指定して手動登録します。"
                                       Margin="0,8,0,0"
                                       Foreground="#94A3B8"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="6"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="戻る"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0"
                        Click="BackButton_OnClick"/>

                <Button Content="登録して詳細へ"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="SaveButton_OnClick"/>
            </StackPanel>

            <Border Grid.RowSpan="7"
                    Background="#66000000"
                    Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Background="#0F172A"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24">
                        <TextBlock Text="登録中です..."
                                   Foreground="#E2E8F0"
                                   FontSize="14"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
