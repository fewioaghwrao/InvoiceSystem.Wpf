<Window x:Class="InvoiceSystem.Wpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ログイン"
        Height="520"
        Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0B1120">

    <Grid>
        <!-- 背景 -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.35"/>
                <GradientStop Color="#111827" Offset="0.7"/>
                <GradientStop Color="#1E1B4B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 疑似グラデーション演出 -->
        <Ellipse Width="320"
                 Height="320"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-80,-60,0,0"
                 IsHitTestVisible="False"
                 Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#38BDF8" Offset="0"/>
                    <GradientStop Color="#0038BDF8" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="360"
                 Height="360"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-100,-80"
                 IsHitTestVisible="False"
                 Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#006366F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- 中央カード -->
        <Grid Margin="24">
            <Border MaxWidth="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="24"
                    Padding="30"
                    BorderBrush="#334155"
                    BorderThickness="1">
                <Border.Background>
                    <SolidColorBrush Color="#CC0F172A"/>
                </Border.Background>

                <Border.Effect>
                    <DropShadowEffect BlurRadius="30"
                                      ShadowDepth="0"
                                      Opacity="0.28"
                                      Color="#000000"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ヘッダ -->
                    <StackPanel Grid.Row="0">
                        <Border HorizontalAlignment="Left"
                                Background="#1E293B"
                                CornerRadius="999"
                                Padding="10,4">
                            <TextBlock Text="Invoice System"
                                       Foreground="#7DD3FC"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock Text="共通ログイン"
                                   Margin="0,16,0,0"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="メールアドレスとパスワードを入力してサインインしてください。"
                                   Margin="0,8,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- メール -->
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="メールアドレス"
                                   Foreground="#E2E8F0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <Border CornerRadius="12"
                                BorderBrush="#475569"
                                BorderThickness="1"
                                Background="#0F172A">
                            <TextBox Height="42"
                                     Padding="12,8"
                                     Background="Transparent"
                                     Foreground="White"
                                     BorderThickness="0"
                                     CaretBrush="White"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <!-- パスワード -->
                    <StackPanel Grid.Row="4">
                        <TextBlock Text="パスワード"
                                   Foreground="#E2E8F0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <!-- 非表示時 -->
                            <Border x:Name="PasswordBoxBorder"
                                    Grid.Column="0"
                                    CornerRadius="12"
                                    BorderBrush="#475569"
                                    BorderThickness="1"
                                    Background="#0F172A">
                                <PasswordBox x:Name="PasswordBox"
                                             Height="42"
                                             Padding="12,8"
                                             Background="Transparent"
                                             Foreground="White"
                                             BorderThickness="0"
                                             PasswordChanged="PasswordBox_OnPasswordChanged"/>
                            </Border>

                            <!-- 表示時 -->
                            <Border x:Name="VisiblePasswordBorder"
                                    Grid.Column="0"
                                    CornerRadius="12"
                                    BorderBrush="#475569"
                                    BorderThickness="1"
                                    Background="#0F172A"
                                    Visibility="Collapsed">
                                <TextBox x:Name="VisiblePasswordTextBox"
                                         Height="42"
                                         Padding="12,8"
                                         Background="Transparent"
                                         Foreground="White"
                                         BorderThickness="0"
                                         CaretBrush="White"
                                         TextChanged="VisiblePasswordTextBox_OnTextChanged"/>
                            </Border>

                            <Button x:Name="TogglePasswordButton"
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Height="42"
                                    Content="表示"
                                    Click="TogglePasswordButton_OnClick"
                                    Background="#1E293B"
                                    Foreground="#E2E8F0"
                                    BorderBrush="#475569"
                                    BorderThickness="1"
                                    FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>

                    <!-- エラー -->
                    <Border Grid.Row="6"
                            Background="#3F1D1D"
                            BorderBrush="#7F1D1D"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#FCA5A5"
                                   TextWrapping="Wrap"
                                   FontSize="12"/>
                    </Border>

                    <!-- ログインボタン -->
                    <Button Grid.Row="8"
                            Height="44"
                            Content="ログイン"
                            Command="{Binding LoginCommand}"
                            Background="#0EA5E9"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            FontSize="14"/>

                    <!-- 補足 -->
                    <TextBlock Grid.Row="10"
                               HorizontalAlignment="Center"
                               Foreground="#64748B"
                               FontSize="11"
                               Text="管理者 / 一般会員 のロールに応じて次画面へ遷移します。"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>