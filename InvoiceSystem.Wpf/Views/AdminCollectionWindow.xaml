<Window x:Class="InvoiceSystem.Wpf.Views.AdminCollectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="催促管理"
        Width="1380"
        Height="940"
        MinWidth="1240"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        Background="#020617">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0284C7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <Style x:Key="ReadOnlyPreviewTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="AcceptsReturn" Value="True"/>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#020617"/>
            <Setter Property="AlternatingRowBackground" Value="#0F172A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E293B"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1E293B"/>
        </Style>

        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Height" Value="40"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#172554"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                CornerRadius="20"
                Padding="20"
                BorderBrush="#1E293B"
                BorderThickness="1"
                Background="#CC0F172A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding InvoiceNumber}"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"/>

                    <TextBlock Margin="0,8,0,0"
                               Text="催促テンプレ作成、次回アクション日設定、履歴記録を一画面で管理できます。"
                               Foreground="#94A3B8"
                               FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="再読込"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ReloadButton_OnClick"/>

                    <Button Content="本文コピー"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CopyBodyButton_OnClick"/>

                    <Button Content="{Binding RecordButtonText}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            IsEnabled="{Binding CanRecord}"
                            Click="RecordButton_OnClick"/>

                    <Button Content="閉じる"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0"
                            Click="CloseButton_OnClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Error -->
        <Border Grid.Row="2"
                Background="#3F1D1D"
                BorderBrush="#7F1D1D"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#FCA5A5"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- KPI -->
        <Border Grid.Row="4"
                CornerRadius="18"
                Padding="16"
                BorderBrush="#1E293B"
                BorderThickness="1"
                Background="#CC0F172A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="14"
                            Padding="16"
                            Background="#0B1220"
                            BorderBrush="#1E293B"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="会員" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding MemberName}"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding MemberEmail}"
                                       Foreground="#94A3B8"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            CornerRadius="14"
                            Padding="16"
                            Background="#0B1220"
                            BorderBrush="#1E293B"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="支払期限 / 請求日" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding DueDateText}"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding InvoiceDateText}"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            CornerRadius="14"
                            Padding="16"
                            Background="#0B1220"
                            BorderBrush="#1E293B"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="請求合計 / 入金済" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding TotalText}"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding PaidTotalText}"
                                       Foreground="#86EFAC"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6"
                            CornerRadius="14"
                            Padding="16"
                            Background="#3B2A12"
                            BorderBrush="#92400E"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="未回収残額" Foreground="#FCD34D" FontSize="11"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding RemainingText}"
                                       Foreground="#FCD34D"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="0円なら催促記録は無効になります"
                                       Foreground="#FDE68A"
                                       FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left -->
                    <ScrollViewer Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border CornerRadius="18"
                                    Padding="16"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    Background="#0F172A">
                                <StackPanel>
                                    <TextBlock Text="督促設定" Style="{StaticResource CardTitleStyle}"/>

                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock Text="チャネル" Style="{StaticResource LabelStyle}"/>
                                        <ComboBox Margin="0,6,0,0"
                                                  ItemsSource="{Binding ChannelOptions}"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="Label"
                                                  SelectedValue="{Binding SelectedChannel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource InputComboBoxStyle}"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock Text="トーン" Style="{StaticResource LabelStyle}"/>
                                        <ComboBox Margin="0,6,0,0"
                                                  ItemsSource="{Binding ToneOptions}"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="Label"
                                                  SelectedValue="{Binding SelectedTone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource InputComboBoxStyle}"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock Text="次回アクション日" Style="{StaticResource LabelStyle}"/>
                                        <DatePicker Margin="0,6,0,0"
                                                    SelectedDate="{Binding NextActionDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Height="34"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock Text="内部メモ" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Margin="0,6,0,0"
                                                 Height="96"
                                                 Text="{Binding Memo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputTextBoxStyle}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    CornerRadius="18"
                                    Padding="16"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    Background="#0F172A">
                                <StackPanel>
                                    <TextBlock Text="補足" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Margin="0,14,0,0"
                                               Foreground="#CBD5E1"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Text="・メール本文はトーンに応じて自動生成されます。&#x0a;・行き違い文言を自動で含めています。&#x0a;・送信自体は行わず、履歴登録のみです。"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Right -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Preview -->
                        <Border Grid.Row="0"
                                CornerRadius="18"
                                Padding="16"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Background="#0F172A">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="220"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="メール送信文面プレビュー"
                                           Style="{StaticResource CardTitleStyle}"/>

                                <TextBlock Grid.Row="2"
                                           Text="件名"
                                           Style="{StaticResource LabelStyle}"/>

                                <TextBox Grid.Row="4"
                                         Text="{Binding SubjectPreview}"
                                         Style="{StaticResource ReadOnlyPreviewTextBoxStyle}"
                                         Height="42"/>

                                <TextBox Grid.Row="6"
                                         Text="{Binding BodyPreview}"
                                         Style="{StaticResource ReadOnlyPreviewTextBoxStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Logs -->
                        <Grid Grid.Row="2">
                            <Border CornerRadius="18"
                                    Padding="16"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    Background="#0F172A">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="督促履歴"
                                               Style="{StaticResource CardTitleStyle}"/>

                                    <DataGrid Grid.Row="2"
                                              ItemsSource="{Binding Logs}"
                                              Style="{StaticResource DataGridStyle}"
                                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                                              RowStyle="{StaticResource DataGridRowStyle}"
                                              CellStyle="{StaticResource DataGridCellStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="日時"
                                                                Binding="{Binding AtText}"
                                                                Width="150"/>
                                            <DataGridTextColumn Header="チャネル"
                                                                Binding="{Binding ChannelLabel}"
                                                                Width="90"/>
                                            <DataGridTextColumn Header="トーン"
                                                                Binding="{Binding ToneLabel}"
                                                                Width="90"/>
                                            <DataGridTextColumn Header="タイトル"
                                                                Binding="{Binding Title}"
                                                                Width="220"/>
                                            <DataGridTextColumn Header="次回"
                                                                Binding="{Binding NextActionDateText}"
                                                                Width="110"/>
                                            <DataGridTextColumn Header="メモ"
                                                                Binding="{Binding Memo}"
                                                                Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border CornerRadius="18"
                                    Padding="16"
                                    Background="#AA020617"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="⏳"
                                               Margin="0,0,8,0"
                                               Foreground="#7DD3FC"
                                               FontSize="14"/>
                                    <TextBlock Text="催促情報を読み込み中です..."
                                               Foreground="#CBD5E1"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>