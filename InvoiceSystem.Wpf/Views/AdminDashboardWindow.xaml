<Window x:Class="InvoiceSystem.Wpf.Views.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="管理者ダッシュボード"
        Width="1320"
        Height="860"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#020617">

    <Window.Resources>
        <!-- DataGrid 全体 -->
        <Style x:Key="AdminDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#020617"/>
            <Setter Property="AlternatingRowBackground" Value="#0F172A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E293B"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1E293B"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- 列ヘッダー -->
        <Style x:Key="AdminDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 行 -->
        <Style x:Key="AdminDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#132033"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="Selector.IsSelectionActive" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#1E40AF"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- セル -->
        <Style x:Key="AdminDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.5"/>
                <GradientStop Color="#111827" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-120,0,0"
                 Opacity="0.18"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#38BDF8" Offset="0"/>
                    <GradientStop Color="#0038BDF8" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-120,-120"
                 Opacity="0.15"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#006366F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    CornerRadius="20"
                    Padding="20"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：タイトル -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="請求・入金ステータスダッシュボード（管理者）"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="売上・未入金・請求書／入金の状況を一目で確認できる管理コンソールです。"
                                   Margin="0,8,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>
                    </StackPanel>

                    <!-- 右：年度切替・ユーザー・操作 -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button Content="← 前年"
                                Width="90"
                                Height="36"
                                Margin="0,0,8,0"
                                Click="PreviousYearButton_OnClick"
                                Background="#0F172A"
                                Foreground="#E2E8F0"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                FontWeight="SemiBold"/>

                        <Border CornerRadius="999"
                                Background="#111827"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Padding="16,8"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedYearText}"
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <Button Content="翌年 →"
                                Width="90"
                                Height="36"
                                Margin="8,0,16,0"
                                Click="NextYearButton_OnClick"
                                Background="#0F172A"
                                Foreground="#E2E8F0"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                FontWeight="SemiBold"/>

                        <Border CornerRadius="999"
                                Background="#0F172A"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Padding="14,8"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ログイン中: "
                                           Foreground="#94A3B8"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentUser.Name, FallbackValue=Admin}"
                                           Foreground="#7DD3FC"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Content="再読込"
                                Width="90"
                                Height="36"
                                Margin="0,0,8,0"
                                Click="ReloadButton_OnClick"
                                Background="#1D4ED8"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"/>

                        <Button Content="ログアウト"
                                Width="100"
                                Height="36"
                                Click="LogoutButton_OnClick"
                                Background="#7F1D1D"
                                Foreground="White"
                                BorderBrush="#B91C1C"
                                BorderThickness="1"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Top navigation -->
            <Border Grid.Row="2"
                    CornerRadius="18"
                    Padding="16"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="管理メニュー"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="主要な一覧画面へ移動できます。"
                                   Margin="0,4,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="12"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="2"
                                 Columns="3">
                        <Button Margin="0,0,12,0"
                                Height="72"
                                Content="請求書一覧"
                                Click="InvoicesButton_OnClick"
                                Background="#0F172A"
                                Foreground="White"
                                BorderBrush="#0EA5E9"
                                BorderThickness="1"
                                FontSize="18"
                                FontWeight="SemiBold"/>

                        <Button Margin="0,0,12,0"
                                Height="72"
                                Content="会員一覧"
                                Click="MembersButton_OnClick"
                                Background="#0F172A"
                                Foreground="White"
                                BorderBrush="#10B981"
                                BorderThickness="1"
                                FontSize="18"
                                FontWeight="SemiBold"/>

                        <Button Height="72"
                                Content="売上一覧"
                                Click="SalesButton_OnClick"
                                Background="#0F172A"
                                Foreground="White"
                                BorderBrush="#6366F1"
                                BorderThickness="1"
                                FontSize="18"
                                FontWeight="SemiBold"/>
                    </UniformGrid>
                </Grid>
            </Border>

            <!-- Main -->
            <ScrollViewer Grid.Row="4"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Error -->
                    <Border Background="#3F1D1D"
                            BorderBrush="#7F1D1D"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14"
                            Margin="0,0,0,14"
                            Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#FCA5A5"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Loading -->
                    <Border Background="#0F172A"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12"
                            Margin="0,0,0,14"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏳"
                                       Margin="0,0,8,0"
                                       Foreground="#7DD3FC"
                                       FontSize="14"/>
                            <TextBlock Text="データを読み込み中です..."
                                       Foreground="#CBD5E1"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- KPI -->
                    <UniformGrid Columns="5" Margin="0,0,0,18">
                        <Border Margin="0,0,12,0"
                                Padding="18"
                                CornerRadius="18"
                                Background="#CC0F172A"
                                BorderBrush="#0EA5E9"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="売上合計（請求金額）"
                                           Foreground="#CBD5E1"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding TotalSalesText}"
                                           Margin="0,10,0,0"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="発行済み請求書の合計金額です。"
                                           Margin="0,8,0,0"
                                           Foreground="#64748B"
                                           FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,12,0"
                                Padding="18"
                                CornerRadius="18"
                                Background="#CC0F172A"
                                BorderBrush="#F59E0B"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="未入金額"
                                           Foreground="#CBD5E1"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding UnpaidAmountText}"
                                           Margin="0,10,0,0"
                                           Foreground="#FCD34D"
                                           FontSize="24"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="未入金・残額の合計です。"
                                           Margin="0,8,0,0"
                                           Foreground="#64748B"
                                           FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,12,0"
                                Padding="18"
                                CornerRadius="18"
                                Background="#CC0F172A"
                                BorderBrush="#334155"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="請求書数"
                                           Foreground="#CBD5E1"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding InvoiceCountText}"
                                           Margin="0,10,0,0"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="集計対象期間の請求書件数です。"
                                           Margin="0,8,0,0"
                                           Foreground="#64748B"
                                           FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,12,0"
                                Padding="18"
                                CornerRadius="18"
                                Background="#CC0F172A"
                                BorderBrush="#10B981"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="入金数"
                                           Foreground="#CBD5E1"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding PaymentCountText}"
                                           Margin="0,10,0,0"
                                           Foreground="#6EE7B7"
                                           FontSize="24"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="登録済み入金明細の件数です。"
                                           Margin="0,8,0,0"
                                           Foreground="#64748B"
                                           FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <Border Padding="18"
                                CornerRadius="18"
                                Background="#CC0F172A"
                                BorderBrush="#6366F1"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="回収率"
                                           Foreground="#CBD5E1"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding RecoveryRateText}"
                                           Margin="0,10,0,0"
                                           Foreground="#C7D2FE"
                                           FontSize="24"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="入金済み合計 ÷ 請求合計です。"
                                           Margin="0,8,0,0"
                                           Foreground="#64748B"
                                           FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- 2 columns -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Unpaid top5 -->
                        <Border Grid.Column="0"
                                Margin="0,0,10,0"
                                CornerRadius="18"
                                Background="#CC0F172A"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="未入金一覧（Top5）"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <DataGrid Grid.Row="2"
          ItemsSource="{Binding UnpaidInvoices}"
          Style="{StaticResource AdminDataGridStyle}"
          ColumnHeaderStyle="{StaticResource AdminDataGridColumnHeaderStyle}"
          RowStyle="{StaticResource AdminDataGridRowStyle}"
          CellStyle="{StaticResource AdminDataGridCellStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="請求番号"
                            Binding="{Binding InvoiceNumber}"
                            Width="140"/>
                                        <DataGridTextColumn Header="顧客"
                            Binding="{Binding ClientName}"
                            Width="*"/>
                                        <DataGridTextColumn Header="残額"
                            Binding="{Binding RemainingTotal, StringFormat={}{0:C0}}"
                            Width="120"/>
                                        <DataGridTextColumn Header="期限超過"
                    Binding="{Binding OverdueStatusText}"
                    Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- Monthly sales -->
                        <Border Grid.Column="1"
        Margin="10,0,0,0"
        CornerRadius="18"
        Background="#CC0F172A"
        BorderBrush="#1E293B"
        BorderThickness="1"
        Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="月別売上"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="SemiBold"/>

                                <oxy:PlotView Grid.Row="2"
              Model="{Binding MonthlySalesPlotModel}"
              Controller="{Binding FixedPlotController}"
              Background="Transparent"
              BorderThickness="0"
              Margin="0,0,0,4"
              IsManipulationEnabled="False" />

                                <TextBlock Grid.Row="4"
                   Text="請求金額ベースの月次推移を表示しています。"
                   Foreground="#94A3B8"
                   FontSize="11"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Worst top5 -->
                    <Border Margin="0,0,0,18"
                            CornerRadius="18"
                            Background="#CC0F172A"
                            BorderBrush="#1E293B"
                            BorderThickness="1"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="回収率ワースト顧客 TOP5"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="2"
                                       Text="※ 未回収がある顧客のみ。回収率が低い順に表示します。"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                            <DataGrid Grid.Row="4"
          ItemsSource="{Binding WorstCustomers}"
          Style="{StaticResource AdminDataGridStyle}"
          ColumnHeaderStyle="{StaticResource AdminDataGridColumnHeaderStyle}"
          RowStyle="{StaticResource AdminDataGridRowStyle}"
          CellStyle="{StaticResource AdminDataGridCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="顧客"
                            Binding="{Binding MemberName}"
                            Width="*"/>
                                    <DataGridTextColumn Header="回収率"
                            Binding="{Binding RecoveryRate, StringFormat={}{0:F1}%}"
                            Width="120"/>
                                    <DataGridTextColumn Header="未回収"
                            Binding="{Binding RemainingTotal, StringFormat={}{0:C0}}"
                            Width="140"/>
                                    <DataGridTextColumn Header="請求合計"
                            Binding="{Binding InvoiceTotal, StringFormat={}{0:C0}}"
                            Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Recent logs -->
                    <Border Margin="0,0,0,18"
                            CornerRadius="18"
                            Background="#CC0F172A"
                            BorderBrush="#1E293B"
                            BorderThickness="1"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="最近の操作（直近5件）"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="2"
                                       Text="管理者の操作履歴を簡易表示しています。"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>

                            <DataGrid Grid.Row="4"
          ItemsSource="{Binding RecentLogs}"
          Style="{StaticResource AdminDataGridStyle}"
          ColumnHeaderStyle="{StaticResource AdminDataGridColumnHeaderStyle}"
          RowStyle="{StaticResource AdminDataGridRowStyle}"
          CellStyle="{StaticResource AdminDataGridCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="日時"
                            Binding="{Binding AtText}"
                            Width="160"/>
                                    <DataGridTextColumn Header="操作"
                            Binding="{Binding ActionLabel}"
                            Width="150"/>
                                    <DataGridTextColumn Header="対象"
                            Binding="{Binding TargetLabel}"
                            Width="140"/>
                                    <DataGridTextColumn Header="内容"
                            Binding="{Binding Summary}"
                            Width="*"/>
                                    <DataGridTextColumn Header="actor"
                            Binding="{Binding ActorText}"
                            Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>