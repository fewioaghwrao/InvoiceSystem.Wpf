<Window x:Class="InvoiceSystem.Wpf.Views.PrivacyPolicyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プライバシーポリシー"
        Height="720"
        Width="860"
        MinHeight="640"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="#0B1120">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.35"/>
                <GradientStop Color="#111827" Offset="0.7"/>
                <GradientStop Color="#1E1B4B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="360"
                 Height="360"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-90,-70,0,0"
                 IsHitTestVisible="False"
                 Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#38BDF8" Offset="0"/>
                    <GradientStop Color="#0038BDF8" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-120,-100"
                 IsHitTestVisible="False"
                 Opacity="0.16">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#006366F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="28">
            <Border MaxWidth="820"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="26"
                    Padding="0"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32"
                                      ShadowDepth="0"
                                      Opacity="0.30"
                                      Color="#000000"/>
                </Border.Effect>

                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Border HorizontalAlignment="Left"
                                Background="#1E293B"
                                CornerRadius="999"
                                Padding="10,4">
                            <TextBlock Text="Invoice System"
                                       Foreground="#7DD3FC"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock Text="プライバシーポリシー"
                                   Margin="0,16,0,0"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="本アプリにおける情報の取扱いについて記載しています。"
                                   Margin="0,8,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Row="2"
                            CornerRadius="18"
                            Padding="22"
                            Background="#0F172A"
                            BorderBrush="#334155"
                            BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="本プライバシーポリシーは、本アプリにおける情報の取扱いについて定めるものです。"
                                           Foreground="#CBD5E1"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>

                                <StackPanel Margin="0,18,0,0">
                                    <TextBlock Text="1. 取得する情報"
                                               Foreground="White"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="本アプリでは、画面表示や操作確認を目的として、利用者が任意で入力した情報を扱う場合があります。ただし、実在する個人情報の入力は推奨されていません。"
                                               Foreground="#CBD5E1"
                                               FontSize="13"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Margin="0,18,0,0">
                                    <TextBlock Text="2. 利用目的"
                                               Foreground="White"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="入力された情報は、本アプリのデモ表示および機能確認の目的にのみ利用されます。"
                                               Foreground="#CBD5E1"
                                               FontSize="13"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Margin="0,18,0,0">
                                    <TextBlock Text="3. 第三者提供"
                                               Foreground="White"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="本アプリでは、入力された情報を第三者に提供することはありません。"
                                               Foreground="#CBD5E1"
                                               FontSize="13"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Margin="0,18,0,0">
                                    <TextBlock Text="4. 情報の管理"
                                               Foreground="White"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="本アプリはポートフォリオ目的のデモアプリであり、入力情報の永続的な保存や管理を保証するものではありません。"
                                               Foreground="#CBD5E1"
                                               FontSize="13"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Margin="0,18,0,0">
                                    <TextBlock Text="5. 実運用について"
                                               Foreground="White"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="本アプリは商用サービスではなく、実際の業務利用や実データの登録を想定していません。"
                                               Foreground="#CBD5E1"
                                               FontSize="13"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <TextBlock Margin="0,26,0,0"
                                           Text="※ 本ページはポートフォリオ用の簡易プライバシーポリシーです。"
                                           Foreground="#64748B"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   Text="内容をご確認のうえ、画面を閉じてください。"/>

                        <Button Grid.Column="1"
                                Height="42"
                                Content="閉じる"
                                Click="CloseButton_OnClick"
                                Background="#1E293B"
                                Foreground="#E2E8F0"
                                BorderBrush="#475569"
                                BorderThickness="1"
                                FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>