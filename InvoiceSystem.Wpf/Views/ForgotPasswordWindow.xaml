<Window x:Class="InvoiceSystem.Wpf.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="パスワード再設定"
        Height="420"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0B1120">

    <Grid>
        <!-- 背景 -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.35"/>
                <GradientStop Color="#111827" Offset="0.7"/>
                <GradientStop Color="#1E1B4B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 疑似グラデーション演出 -->
        <Ellipse Width="280"
                 Height="280"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-70,-50,0,0"
                 IsHitTestVisible="False"
                 Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#38BDF8" Offset="0"/>
                    <GradientStop Color="#0038BDF8" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="320"
                 Height="320"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-90,-70"
                 IsHitTestVisible="False"
                 Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#006366F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- 中央カード -->
        <Grid Margin="24">
            <Border MaxWidth="440"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="24"
                    Padding="30"
                    BorderBrush="#334155"
                    BorderThickness="1">
                <Border.Background>
                    <SolidColorBrush Color="#CC0F172A"/>
                </Border.Background>

                <Border.Effect>
                    <DropShadowEffect BlurRadius="30"
                                      ShadowDepth="0"
                                      Opacity="0.28"
                                      Color="#000000"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ヘッダ -->
                    <StackPanel Grid.Row="0">
                        <Border HorizontalAlignment="Left"
                                Background="#1E293B"
                                CornerRadius="999"
                                Padding="10,4">
                            <TextBlock Text="Invoice System"
                                       Foreground="#7DD3FC"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock Text="パスワード再設定"
                                   Margin="0,16,0,0"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="登録済みのメールアドレス宛に、パスワード再設定用リンクを送信します。"
                                   Margin="0,8,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- メール -->
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="メールアドレス"
                                   Foreground="#E2E8F0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <Border CornerRadius="12"
                                BorderBrush="#475569"
                                BorderThickness="1"
                                Background="#0F172A">
                            <TextBox x:Name="EmailTextBox"
                                     Height="42"
                                     Padding="12,8"
                                     Background="Transparent"
                                     Foreground="White"
                                     BorderThickness="0"
                                     CaretBrush="White"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- メッセージ -->
                    <Border x:Name="MessageBorder"
                            Grid.Row="4"
                            Background="#3F1D1D"
                            BorderBrush="#7F1D1D"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Visibility="Collapsed">
                        <TextBlock x:Name="MessageTextBlock"
                                   Foreground="#FCA5A5"
                                   TextWrapping="Wrap"
                                   FontSize="12"/>
                    </Border>

                    <!-- 送信ボタン -->
                    <Button x:Name="SendButton"
                            Grid.Row="6"
                            Height="44"
                            Content="再設定メールを送信"
                            Click="SendButton_OnClick"
                            Background="#0EA5E9"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            FontSize="14"/>

                    <!-- 下部 -->
                    <Grid Grid.Row="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   Text="メール送信後、ブラウザ側の再設定画面から新しいパスワードを登録します。"/>

                        <Button Grid.Column="1"
                                Margin="16,0,0,0"
                                Padding="16,8"
                                Content="閉じる"
                                Click="CloseButton_OnClick"
                                Background="#1E293B"
                                Foreground="#E2E8F0"
                                BorderBrush="#475569"
                                BorderThickness="1"
                                FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
