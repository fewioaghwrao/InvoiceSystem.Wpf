<Window x:Class="InvoiceSystem.Wpf.Views.SalesByMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="売上集計（顧客別）"
        Width="1280"
        Height="820"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        Background="#020617">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="AdminDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#020617"/>
            <Setter Property="AlternatingRowBackground" Value="#0F172A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style x:Key="AdminDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="AdminDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Height" Value="40"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#132033"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AdminDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="20"
                Padding="20"
                BorderBrush="#1E293B"
                BorderThickness="1"
                Background="#CC0F172A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="売上集計（顧客別）"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="顧客ごとの請求合計・入金済み・未回収・回収率を確認できます。"
                               Margin="0,8,0,0"
                               Foreground="#94A3B8"
                               FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="← 前年"
                            Width="90"
                            Height="36"
                            Margin="0,0,8,0"
                            Click="PreviousYearButton_OnClick"
                            Background="#0F172A"
                            Foreground="#E2E8F0"
                            BorderBrush="#334155"
                            BorderThickness="1"/>

                    <Border CornerRadius="999"
                            Background="#111827"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            Padding="16,8">
                        <TextBlock Text="{Binding SelectedYearText}"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <Button Content="翌年 →"
                            Width="90"
                            Height="36"
                            Margin="8,0,0,0"
                            Click="NextYearButton_OnClick"
                            Background="#0F172A"
                            Foreground="#E2E8F0"
                            BorderBrush="#334155"
                            BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                CornerRadius="18"
                Padding="16"
                BorderBrush="#1E293B"
                BorderThickness="1"
                Background="#CC0F172A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="月" Margin="0,0,0,6" Foreground="#CBD5E1"/>
                    <ComboBox ItemsSource="{Binding MonthOptions}"
                  SelectedItem="{Binding SelectedMonth}"
                  DisplayMemberPath="Label"
                  Height="34"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="キーワード" Margin="0,0,0,6" Foreground="#CBD5E1"/>
                    <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                 Height="34"/>
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Margin="0,0,12,0">
                    <Button Content="検索"
                Height="34"
                Click="SearchButton_OnClick"
                Background="#1D4ED8"
                Foreground="White"
                BorderThickness="0"/>
                </StackPanel>

                <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Margin="0,0,12,0">
                    <Button Content="CSV出力"
                Height="34"
                Click="ExportCsvButton_OnClick"
                Background="#0F172A"
                Foreground="#E2E8F0"
                BorderBrush="#334155"
                BorderThickness="1"/>
                </StackPanel>

                <StackPanel Grid.Column="5" VerticalAlignment="Bottom">
                    <Button Content="← 売上一覧へ戻る"
                Height="34"
                Click="BackToSalesButton_OnClick"
                Background="#0F172A"
                Foreground="#E2E8F0"
                BorderBrush="#334155"
                BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="4" Columns="4">
            <Border Margin="0,0,12,0" Padding="18" CornerRadius="18" Background="#CC0F172A" BorderBrush="#0EA5E9" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="請求合計" Foreground="#CBD5E1" FontSize="12"/>
                    <TextBlock Text="{Binding InvoiceTotalText}" Margin="0,10,0,0" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Margin="0,0,12,0" Padding="18" CornerRadius="18" Background="#CC0F172A" BorderBrush="#10B981" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="入金済み" Foreground="#CBD5E1" FontSize="12"/>
                    <TextBlock Text="{Binding PaidTotalText}" Margin="0,10,0,0" Foreground="#6EE7B7" FontSize="24" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Margin="0,0,12,0" Padding="18" CornerRadius="18" Background="#CC0F172A" BorderBrush="#F59E0B" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="未回収" Foreground="#CBD5E1" FontSize="12"/>
                    <TextBlock Text="{Binding RemainingTotalText}" Margin="0,10,0,0" Foreground="#FCD34D" FontSize="24" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Padding="18" CornerRadius="18" Background="#CC0F172A" BorderBrush="#6366F1" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="回収率" Foreground="#CBD5E1" FontSize="12"/>
                    <TextBlock Text="{Binding RecoveryRateText}" Margin="0,10,0,0" Foreground="#C7D2FE" FontSize="24" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#3F1D1D"
                    BorderBrush="#7F1D1D"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14"
                    Margin="0,0,0,10"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="1"
                    Background="#0F172A"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    Margin="0,0,0,10"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="データを読み込み中です..." Foreground="#CBD5E1"/>
            </Border>

            <Border Grid.Row="3"
                    CornerRadius="18"
                    Background="#CC0F172A"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Padding="16">
                <DataGrid ItemsSource="{Binding Rows}"
                          Style="{StaticResource AdminDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource AdminDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource AdminDataGridRowStyle}"
                          CellStyle="{StaticResource AdminDataGridCellStyle}"
                          MouseDoubleClick="SalesByMemberGrid_OnMouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="顧客"
                                            Binding="{Binding MemberName}"
                                            Width="*"/>
                        <DataGridTextColumn Header="請求合計"
                                            Binding="{Binding InvoiceTotal, StringFormat={}{0:C0}}"
                                            Width="140"/>
                        <DataGridTextColumn Header="入金済"
                                            Binding="{Binding PaidTotal, StringFormat={}{0:C0}}"
                                            Width="140"/>
                        <DataGridTextColumn Header="未回収"
                                            Binding="{Binding RemainingTotal, StringFormat={}{0:C0}}"
                                            Width="140"/>
                        <DataGridTextColumn Header="回収率"
                                            Binding="{Binding RecoveryRateText}"
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding PageText}"
                       VerticalAlignment="Center"
                       Foreground="#94A3B8"
                       FontSize="12"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="← 前へ"
                        Width="100"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="PrevPageButton_OnClick"
                        Background="#0F172A"
                        Foreground="#E2E8F0"
                        BorderBrush="#334155"
                        BorderThickness="1"/>
                <Button Content="次へ →"
                        Width="100"
                        Height="34"
                        Click="NextPageButton_OnClick"
                        Background="#0F172A"
                        Foreground="#E2E8F0"
                        BorderBrush="#334155"
                        BorderThickness="1"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
