<Window x:Class="InvoiceSystem.Wpf.Views.MemberInvoiceListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="会員用請求書一覧"
        Height="920"
        Width="1320"
        MinHeight="860"
        MinWidth="1120"
        WindowStartupLocation="CenterScreen"
        Background="#0B1120">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Background" Value="#CC0F172A"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="#3F1D1D"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
        </Style>

        <Style x:Key="SmallActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FilterLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#0F172A"/>
            <Setter Property="AlternatingRowBackground" Value="#111C31"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E293B"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1E293B"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="RowHeight" Value="50"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="StatusTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.35"/>
                <GradientStop Color="#111827" Offset="0.72"/>
                <GradientStop Color="#1E1B4B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-100,0,0"
                 IsHitTestVisible="False"
                 Opacity="0.16">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#38BDF8" Offset="0"/>
                    <GradientStop Color="#0038BDF8" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="460"
                 Height="460"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-140,-110"
                 IsHitTestVisible="False"
                 Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#006366F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="24"
                    Padding="24"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border HorizontalAlignment="Left"
                                Background="#1E293B"
                                CornerRadius="999"
                                Padding="10,4">
                            <TextBlock Text="Invoice System / Member Invoices"
                                       Foreground="#7DD3FC"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock Text="会員用請求書一覧"
                                   Margin="0,16,0,0"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="自分宛ての請求書、支払期限、入金状況を確認できます。"
                                   Margin="0,8,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Right"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding WelcomeMessage}"/>

                        <TextBlock Margin="0,4,0,0"
                                   HorizontalAlignment="Right"
                                   Foreground="#94A3B8"
                                   FontSize="12"
                                   Text="{Binding SubWelcomeMessage}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    CornerRadius="18"
                    Padding="16"
                    BorderBrush="#92400E"
                    BorderThickness="1"
                    Background="#4A2C0A"
                    Visibility="{Binding OverdueBannerVisibility}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠"
                               FontSize="18"
                               Foreground="#FCD34D"
                               Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="お支払いの遅れている請求があります"
                                   Foreground="#FDE68A"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="期限超過の請求が一覧に含まれています。内容をご確認ください。"
                                   Foreground="#FDE68A"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="検索条件" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="年・月・ステータス・キーワードで絞り込みできます。"
                                   Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="年" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding YearOptions}"
                                      SelectedItem="{Binding SelectedYear}"
                                      Style="{StaticResource DarkComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="月" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding MonthOptions}"
                                      SelectedItem="{Binding SelectedMonthOption}"
                                      DisplayMemberPath="Label"
                                      Style="{StaticResource DarkComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="ステータス" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding SelectedStatusOption}"
                                      DisplayMemberPath="Label"
                                      Style="{StaticResource DarkComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock Text="検索" Style="{StaticResource FilterLabelStyle}"/>
                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Width="120"
                                Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding ClearCommand}"
                                Content="条件クリア"/>

                        <Button Width="120"
                                Margin="12,0,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SearchCommand}"
                                Content="検索"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="請求書一覧" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding SummaryText}"
                                       Style="{StaticResource MutedTextStyle}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Foreground="#7DD3FC"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="{Binding LoadingMessage}"
                                   Visibility="{Binding LoadingVisibility}"/>
                    </Grid>

                    <DataGrid Grid.Row="2"
          ItemsSource="{Binding InvoiceRows}"
          SelectionMode="Single"
          SelectionUnit="FullRow"
          FrozenColumnCount="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="請求書番号"
                                                Width="180"
                                                Binding="{Binding InvoiceNumber}"/>

                            <DataGridTextColumn Header="請求日"
                                                Width="130"
                                                Binding="{Binding IssuedAtText}"/>

                            <DataGridTextColumn Header="支払期限"
                                                Width="130"
                                                Binding="{Binding DueAtText}"/>

                            <DataGridTextColumn Header="請求金額"
                                                Width="140"
                                                Binding="{Binding TotalAmountText}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="ステータス" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBackground}"
                                                BorderBrush="{Binding StatusBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusName}"
                                                       Foreground="{Binding StatusForeground}"
                                                       Style="{StaticResource StatusTextBlockStyle}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="期限超過" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#4A2C0A"
                                                BorderBrush="#92400E"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding OverdueBadgeVisibility}">
                                            <TextBlock Text="期限超過"
                                                       Foreground="#FCD34D"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="操作" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Button Content="詳細"
                                                    Width="78"
                                                    Style="{StaticResource SmallActionButtonStyle}"
                                                    Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>

                                            <Button Content="PDF"
                                                    Width="78"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource SmallActionButtonStyle}"
                                                    Command="{Binding DataContext.OpenPdfCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="8" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="ページ情報："
                                   Foreground="#94A3B8"
                                   FontSize="12"/>
                        <TextBlock Margin="8,0,0,0"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="{Binding PageInfoText}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="100"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding PrevCommand}"
                            Content="前へ"/>

                    <Button Grid.Column="3"
                            Width="100"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding NextCommand}"
                            Content="次へ"/>

                    <Button Grid.Column="5"
                            Width="150"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            Content="再読み込み"/>

                    <Button Grid.Column="7"
                            Width="180"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding BackToDashboardCommand}"
                            Content="ダッシュボードへ戻る"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>