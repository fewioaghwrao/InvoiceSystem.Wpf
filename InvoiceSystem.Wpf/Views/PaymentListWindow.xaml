<Window x:Class="InvoiceSystem.Wpf.Views.PaymentListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="入金一覧"
        Width="1360"
        Height="860"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        Background="#020617">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="FilterLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="TextBoxStyleDark" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="ComboBoxStyleDark" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PaymentDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#020617"/>
            <Setter Property="AlternatingRowBackground" Value="#0F172A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E293B"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1E293B"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="PaymentDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PaymentDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#132033"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PaymentDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="GridActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.5"/>
                <GradientStop Color="#111827" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="380"
                 Height="380"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-100,0,0"
                 Opacity="0.15"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#10B981" Offset="0"/>
                    <GradientStop Color="#0010B981" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="380"
                 Height="380"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-120,-120"
                 Opacity="0.15"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#006366F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    CornerRadius="20"
                    Padding="20"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="入金一覧"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="入金明細を一覧で確認し、請求書への割当状況を確認できます。"
                                   Margin="0,8,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="+ 入金登録"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0"
                                Click="CreateButton_OnClick"/>

                        <Button Content="再読込"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,8,0"
                                Click="ReloadButton_OnClick"/>

                        <Button Content="閉じる"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="CloseButton_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Error -->
            <Border Grid.Row="2"
                    Background="#3F1D1D"
                    BorderBrush="#7F1D1D"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FCA5A5"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Search -->
            <Border Grid.Row="4"
                    CornerRadius="18"
                    Padding="16"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="検索条件"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="年・月・割当ステータス・キーワードで絞り込めます。"
                                   Margin="0,4,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="12"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="年" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding YearOptions}"
                                      SelectedItem="{Binding SelectedYear}"
                                      Style="{StaticResource ComboBoxStyleDark}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="月" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding MonthOptions}"
                                      SelectedItem="{Binding SelectedMonth}"
                                      DisplayMemberPath="Label"
                                      Style="{StaticResource ComboBoxStyleDark}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="割当ステータス" Style="{StaticResource FilterLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding SelectedStatus}"
                                      DisplayMemberPath="Label"
                                      Style="{StaticResource ComboBoxStyleDark}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,12,0">
                            <TextBlock Text="検索（入金ID / 名義 / 請求書番号）"
                                       Style="{StaticResource FilterLabelStyle}"/>
                            <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyleDark}"/>
                        </StackPanel>

                        <Button Grid.Column="4"
                                Margin="0,24,12,0"
                                Content="検索"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SearchButton_OnClick"/>

                        <Button Grid.Column="5"
                                Margin="0,24,12,0"
                                Content="リセット"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ResetButton_OnClick"/>

                        <Border Grid.Column="6"
                                Margin="0,24,0,0"
                                Height="36"
                                CornerRadius="10"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Background="#0F172A">
                            <TextBlock Text="{Binding CurrentPageText}"
                                       Foreground="#CBD5E1"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Summary -->
            <UniformGrid Grid.Row="6" Columns="3">
                <Border Margin="0,0,12,0"
                        Padding="18"
                        CornerRadius="18"
                        Background="#CC0F172A"
                        BorderBrush="#10B981"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="入金合計"
                                   Foreground="#CBD5E1"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding TotalAmountText}"
                                   Margin="0,10,0,0"
                                   Foreground="#6EE7B7"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="対象条件での入金総額です。"
                                   Margin="0,8,0,0"
                                   Foreground="#64748B"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,12,0"
                        Padding="18"
                        CornerRadius="18"
                        Background="#CC0F172A"
                        BorderBrush="#38BDF8"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="割当済合計"
                                   Foreground="#CBD5E1"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding AllocatedTotalText}"
                                   Margin="0,10,0,0"
                                   Foreground="#7DD3FC"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="請求書へ割り当て済みの金額です。"
                                   Margin="0,8,0,0"
                                   Foreground="#64748B"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border Padding="18"
                        CornerRadius="18"
                        Background="#CC0F172A"
                        BorderBrush="#F59E0B"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="未割当合計"
                                   Foreground="#CBD5E1"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding UnallocatedTotalText}"
                                   Margin="0,10,0,0"
                                   Foreground="#FCD34D"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="まだ請求書に割り当てられていない金額です。"
                                   Margin="0,8,0,0"
                                   Foreground="#64748B"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Grid -->
            <Border Grid.Row="8"
                    CornerRadius="18"
                    Padding="16"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding ResultCountText}"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="2"
                               Text="検索条件に一致した入金明細を表示します。"
                               Foreground="#94A3B8"
                               FontSize="12"/>

                    <DataGrid Grid.Row="4"
                              Name="PaymentGrid"
                              ItemsSource="{Binding Payments}"
                              SelectedItem="{Binding SelectedPayment}"
                              Style="{StaticResource PaymentDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource PaymentDataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource PaymentDataGridRowStyle}"
                              CellStyle="{StaticResource PaymentDataGridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="入金ID"
                                                Binding="{Binding PaymentIdText}"
                                                Width="100"/>
                            <DataGridTextColumn Header="入金日"
                                                Binding="{Binding PaymentDateText}"
                                                Width="120"/>
                            <DataGridTextColumn Header="入金名義"
                                                Binding="{Binding PayerName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="割当状態"
                                                Binding="{Binding StatusText}"
                                                Width="110"/>
                            <DataGridTextColumn Header="入金額"
                                                Binding="{Binding Amount, StringFormat={}{0:C0}}"
                                                Width="120"/>
                            <DataGridTextColumn Header="割当済"
                                                Binding="{Binding AllocatedAmount, StringFormat={}{0:C0}}"
                                                Width="120"/>
                            <DataGridTextColumn Header="未割当"
                                                Binding="{Binding UnallocatedAmount, StringFormat={}{0:C0}}"
                                                Width="120"/>
                            <DataGridTextColumn Header="請求書"
                                                Binding="{Binding InvoiceNumbersText}"
                                                Width="220"/>

                            <DataGridTemplateColumn Header="操作" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="詳細"
                                                Style="{StaticResource GridActionButtonStyle}"
                                                Click="DetailButton_OnClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Footer -->
            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Height="36"
                        Padding="12,0"
                        CornerRadius="10"
                        Background="#0F172A"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentPageText}"
                               Foreground="#CBD5E1"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Content="← 前へ"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"
                            IsEnabled="{Binding CanMovePrev}"
                            Click="PrevPageButton_OnClick"/>

                    <Button Content="次へ →"
                            Style="{StaticResource SecondaryButtonStyle}"
                            IsEnabled="{Binding CanMoveNext}"
                            Click="NextPageButton_OnClick"/>
                </StackPanel>
            </Grid>

            <!-- Loading overlay -->
            <Border Grid.RowSpan="11"
                    Background="#66000000"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Background="#0F172A"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24">
                        <StackPanel>
                            <TextBlock Text="⏳"
                                       HorizontalAlignment="Center"
                                       Foreground="#7DD3FC"
                                       FontSize="24"/>
                            <TextBlock Text="入金一覧を読み込み中です..."
                                       Margin="0,10,0,0"
                                       Foreground="#E2E8F0"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>