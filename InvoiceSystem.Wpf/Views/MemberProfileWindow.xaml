<Window x:Class="InvoiceSystem.Wpf.Views.MemberProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="プロフィール"
        Height="860"
        Width="1100"
        MinHeight="760"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="#0B1120">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Background" Value="#CC0F172A"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="BorderBrush" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="#3F1D1D"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
        </Style>

        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.35"/>
                <GradientStop Color="#111827" Offset="0.72"/>
                <GradientStop Color="#1E1B4B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-100,0,0"
                 IsHitTestVisible="False"
                 Opacity="0.16">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#38BDF8" Offset="0"/>
                    <GradientStop Color="#0038BDF8" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="440"
                 Height="440"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-130,-100"
                 IsHitTestVisible="False"
                 Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#006366F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="24"
                    Padding="24"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border HorizontalAlignment="Left"
                                Background="#1E293B"
                                CornerRadius="999"
                                Padding="10,4">
                            <TextBlock Text="Invoice System / Profile"
                                       Foreground="#7DD3FC"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock Text="プロフィール"
                                   Margin="0,16,0,0"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="請求書の宛名や連絡先に使用される情報です。"
                                   Margin="0,8,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Right"
                                   Foreground="#7DD3FC"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="{Binding LoadingMessage}"
                                   Visibility="{Binding LoadingVisibility}"/>

                        <TextBlock Margin="0,10,0,0"
                                   HorizontalAlignment="Right"
                                   Foreground="#FDA4AF"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Width="320"
                                   Text="{Binding ErrorMessage}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="登録情報の確認・変更" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="氏名、メールアドレス、電話番号、郵便番号、住所を編集できます。"
                                   Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="氏名 *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="メールアドレス *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="※ Lite版のため、変更確認メールは省略しています。"
                                       Style="{StaticResource MutedTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="電話番号" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="郵便番号" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                     Text="{Binding PostalCode, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="住所" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                     Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="4"
                            Background="#2A0F1A"
                            BorderBrush="#7F1D1D"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14"
                            Visibility="{Binding EmailChangedNoticeVisibility}">
                        <StackPanel>
                            <TextBlock Text="メールアドレスが変更されています"
                                       Foreground="#FCA5A5"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#FECACA"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="{Binding EmailChangedText}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Width="130"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding WithdrawCommand}"
                            Content="退会する"/>

                    <Button Grid.Column="3"
                            Width="120"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding BackCommand}"
                            Content="戻る"/>

                    <Button Grid.Column="5"
                            Width="120"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveCommand}"
                            Content="保存"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
