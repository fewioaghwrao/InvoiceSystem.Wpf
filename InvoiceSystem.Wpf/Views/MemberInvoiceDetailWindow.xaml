<Window x:Class="InvoiceSystem.Wpf.Views.MemberInvoiceDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="請求書詳細"
        Height="880"
        Width="1120"
        MinHeight="780"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#0B1120">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Background" Value="#CC0F172A"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#132032"/>
            <Setter Property="BorderBrush" Value="#334155"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0F172A" Offset="0.35"/>
                <GradientStop Color="#111827" Offset="0.72"/>
                <GradientStop Color="#1E1B4B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-100,0,0"
                 IsHitTestVisible="False"
                 Opacity="0.16">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#38BDF8" Offset="0"/>
                    <GradientStop Color="#0038BDF8" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="440"
                 Height="440"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-130,-100"
                 IsHitTestVisible="False"
                 Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#006366F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ヘッダー -->
            <Border Grid.Row="0"
                    CornerRadius="24"
                    Padding="24"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    Background="#CC0F172A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border HorizontalAlignment="Left"
                                Background="#1E293B"
                                CornerRadius="999"
                                Padding="10,4">
                            <TextBlock Text="Invoice System / Member Invoice Detail"
                                       Foreground="#7DD3FC"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock Text="請求書詳細"
                                   Margin="0,16,0,0"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="請求内容、支払期限、入金状況を確認できます。"
                                   Margin="0,8,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="LoadingText"
                                   HorizontalAlignment="Right"
                                   Foreground="#7DD3FC"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text=""
                                   Visibility="Collapsed"/>

                        <TextBlock x:Name="ErrorText"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Right"
                                   Foreground="#FDA4AF"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Width="300"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 上部操作 -->
            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="操作" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="一覧へ戻る、またはPDFを表示できます。"
                                   Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="160"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="BackButton_Click"
                            Content="請求書一覧へ戻る"/>

                    <Button x:Name="PdfButton"
                            Grid.Column="4"
                            Width="140"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="PdfButton_Click"
                            Content="PDF表示"/>
                </Grid>
            </Border>

            <!-- 詳細本体 -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 請求番号 / ステータス -->
                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="請求書番号" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock x:Name="InvoiceNumberText"
                                       Margin="0,8,0,0"
                                       Text="---"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="SemiBold"/>

                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Border x:Name="StatusBadge"
                                        Style="{StaticResource StatusBadgeStyle}">
                                    <TextBlock x:Name="StatusText"
                                               Text="---"
                                               Foreground="#E2E8F0"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                </Border>

                                <Border x:Name="OverdueBadge"
                                        Margin="10,0,0,0"
                                        CornerRadius="999"
                                        Padding="12,5"
                                        BorderThickness="1"
                                        Background="#4A2C0A"
                                        BorderBrush="#92400E"
                                        Visibility="Collapsed">
                                    <TextBlock Text="⚠ 期限超過"
                                               Foreground="#FCD34D"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="請求日"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource MutedTextStyle}"/>
                                <TextBlock x:Name="InvoiceDateText"
                                           Margin="0,6,0,0"
                                           HorizontalAlignment="Right"
                                           Text="---"
                                           Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="支払期限"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource MutedTextStyle}"/>
                                <TextBlock x:Name="DueDateText"
                                           Margin="0,6,0,0"
                                           HorizontalAlignment="Right"
                                           Text="---"
                                           Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 金額情報 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="請求金額" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock x:Name="TotalAmountText"
                                       Margin="0,10,0,0"
                                       Text="---"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="入金済み" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock x:Name="PaidAmountText"
                                       Margin="0,10,0,0"
                                       Text="---"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="残額" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock x:Name="RemainingAmountText"
                                       Margin="0,10,0,0"
                                       Text="---"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 備考 -->
                <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="備考" Style="{StaticResource SectionTitleStyle}"/>
                        <Border Margin="0,14,0,0"
                                CornerRadius="16"
                                Padding="16"
                                Background="#0B1220"
                                BorderBrush="#233044"
                                BorderThickness="1">
                            <TextBlock x:Name="RemarksText"
                                       Text="備考はありません。"
                                       Foreground="#CBD5E1"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- フッター -->
            <Border Grid.Row="6"
                    CornerRadius="18"
                    Padding="14,12"
                    BorderBrush="#233044"
                    BorderThickness="1"
                    Background="#99101826">
                <TextBlock Text="Invoice Detail / Member"
                           Foreground="#64748B"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>
